{
	"name": "fin",
	"version": "0.0.1",
	"type": "module",
	"private": true,
	"repository": {
		"type": "git",
		"url": "https://github.com/u29dc/fin.git"
	},
	"scripts": {
		"prepare": "husky",
		"build": "./scripts/rust/install_fin.sh",
		"build:release": "cargo build --workspace --release",
		"run": "cargo run -p fin-cli --",
		"tui": "cargo run -p fin-tui --",
		"fmt": "cargo fmt --all",
		"fmt:check": "cargo fmt --all --check",
		"lint": "cargo clippy --workspace --all-targets --all-features -- -D warnings",
		"check": "cargo check --workspace",
		"test": "cargo test --workspace",
		"guard:legacy": "./scripts/rust/guard_no_legacy.sh",
		"quality": "STATUS=0; bun run guard:legacy || STATUS=1; cargo fmt --all --check || STATUS=1; cargo clippy --workspace --all-targets --all-features -- -D warnings || STATUS=1; cargo check --workspace || STATUS=1; cargo test --workspace || STATUS=1; exit $STATUS",
		"verify:cli-path": "./scripts/rust/verify_fin_path.sh",
		"certify:commands": "./scripts/cert/certify_commands.sh",
		"clean": "cargo clean && rm -rf .tmp/cert-results"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.4.2",
		"@commitlint/config-conventional": "^20.4.2",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.1"
	}
}
