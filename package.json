{
	"name": "fin",
	"version": "0.0.1",
	"type": "module",
	"private": true,
	"repository": {
		"type": "git",
		"url": "https://github.com/u29dc/fin.git"
	},
	"scripts": {
		"prepare": "husky",
		"fin:dev": "cargo run -p fin-cli --",
		"fin:tui": "cargo run -p fin-tui --",
		"build": "./scripts/rust/install_fin.sh",
		"build:release": "cargo build --workspace --release",
		"util:guard:legacy": "./scripts/rust/guard_no_legacy.sh",
		"util:format": "cargo fmt --all",
		"util:lint": "cargo clippy --workspace --all-targets --all-features -- -D warnings",
		"util:types": "cargo check --workspace",
		"util:test": "cargo test --workspace",
		"util:build": "cargo build --workspace",
		"util:check": "bun run util:guard:legacy && cargo fmt --all --check && bun run util:lint && bun run util:types && bun run util:test && bun run util:build",
		"util:verify:cli-path": "./scripts/rust/verify_fin_path.sh",
		"run": "bun run fin:dev",
		"tui": "bun run fin:tui",
		"fmt": "bun run util:format",
		"lint": "bun run util:lint",
		"check": "bun run util:types",
		"test": "bun run util:test",
		"quality": "bun run util:check",
		"verify:cli-path": "bun run util:verify:cli-path",
		"certify:commands": "./scripts/cert/certify_commands.sh",
		"clean": "cargo clean && rm -rf .tmp/cert-results"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.4.2",
		"@commitlint/config-conventional": "^20.4.2",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.1"
	}
}
