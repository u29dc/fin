      "patterns": ["YOUR EMPLOYER NAME"],
      "target": "Salary",
      "category": "Income"
    },
    {
      "patterns": ["DIVIDEND PAYMENT"],
      "target": "Dividends",
      "category": "Income"
    },
    {
      "patterns": ["TESCO", "SAINSBURY", "WAITROSE", "LIDL", "ALDI"],
      "target": "Groceries",
      "category": "Groceries"
    },
    {
      "patterns": ["AMAZON", "EBAY"],
      "target": "Shopping",
      "category": "Shopping"
    },
    {
      "patterns": ["LOCAL COFFEE SHOP"],
      "target": "Coffee Shop",
      "category": "Food"
    },
    {
      "patterns": ["YOUR BUSINESS NAME", "Sent money to Your Name"],
